---
const year = new Date().getFullYear();

const serviceLinks = [
  { label: 'Kitchen Renovation',     href: '/services/kitchen-renovation' },
  { label: 'Bathroom Renovation',    href: '/services/bathroom-renovation' },
  { label: 'Basement Renovation',    href: '/services/basement-renovation' },
  { label: 'Painting',               href: '/services/painting' },
  { label: 'Roof Replacement',       href: '/services/roof-replacement' },
  { label: 'Roof Repairs',           href: '/services/roof-repairs' },
  { label: 'Metal Roofing',          href: '/services/metal-roofing' },
  { label: 'Exterior Siding',        href: '/services/siding' },
];

const companyLinks = [
  { label: 'About Us',        href: '/about' },
  { label: 'Our Work',        href: '/our-work' },
  { label: 'Testimonials',    href: '/testimonials' },
  { label: 'Blog',            href: '/blog' },
  { label: 'FAQ',             href: '/faq' },
  { label: 'Service Areas',   href: '/service-areas' },
  { label: 'Contact',         href: '/contact' },
];
---

<footer style="background-color:var(--color-primary-900); color:rgba(255,255,255,0.75); border-top:1px solid rgba(255,255,255,0.06);" role="contentinfo">

  <!-- Main footer grid -->
  <div class="container" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:3rem; padding-block:4rem;">

    <!-- Col 1: Brand -->
    <div>
      <a href="/" style="display:inline-block; margin-bottom:1.25rem; text-decoration:none;">
        <img src="/Assets/logo-02-reversed-charcoal.svg" alt="Top Design Renovation" width="200" height="75" loading="lazy" style="height:75px; width:auto;" />
      </a>
      <p style="font-size:0.875rem; line-height:1.7; color:rgba(255,255,255,0.6); margin-bottom:1.5rem; max-width:260px;">
        Quality renovation, construction, painting &amp; roofing services across [City] and the surrounding area.
      </p>
      <!-- Social icons -->
      <div style="display:flex; gap:0.75rem;">
        <a href="https://facebook.com/[handle]" aria-label="Facebook" rel="noopener" target="_blank" class="footer-social">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
        </a>
        <a href="https://instagram.com/[handle]" aria-label="Instagram" rel="noopener" target="_blank" class="footer-social">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
      </div>
    </div>

    <!-- Col 2: Services -->
    <div>
      <p class="footer-heading">Services</p>
      <ul role="list" style="list-style:none; display:flex; flex-direction:column; gap:0.4rem;">
        {serviceLinks.map(l => (
          <li><a href={l.href} class="footer-link">{l.label}</a></li>
        ))}
        <li>
          <a href="/services" class="footer-link" style="color:var(--color-accent-300); font-weight:500;">
            View All Services →
          </a>
        </li>
      </ul>
    </div>

    <!-- Col 3: Company -->
    <div>
      <p class="footer-heading">Company</p>
      <ul role="list" style="list-style:none; display:flex; flex-direction:column; gap:0.4rem;">
        {companyLinks.map(l => (
          <li><a href={l.href} class="footer-link">{l.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Col 4: Contact -->
    <div>
      <p class="footer-heading">Contact Us</p>
      <address style="font-style:normal; display:flex; flex-direction:column; gap:0.85rem; font-size:0.875rem; color:rgba(255,255,255,0.65);">
        <a href="tel:[Phone]" class="footer-contact-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.12 1.18 2 2 0 012.11 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          [Phone]
        </a>
        <a href="mailto:info@[domain].ca" class="footer-contact-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          info@[domain].ca
        </a>
        <span class="footer-contact-item" style="cursor:default;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          [Address], [City], [Province]
        </span>
        <span class="footer-contact-item" style="cursor:default;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Mon–Fri 8:00am – 5:00pm
        </span>
      </address>

      <div style="margin-top:1.5rem;">
        <a href="/free-estimate" class="btn-primary" style="font-size:0.75rem; padding:0.6rem 1.25rem;">
          Free Estimate →
        </a>
      </div>
    </div>

  </div>

  <!-- Bottom bar -->
  <div style="border-top:1px solid rgba(255,255,255,0.06);">
    <div class="container" style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; padding-block:1.25rem; font-size:0.78rem; color:rgba(255,255,255,0.4);">
      <p>© {year} [Company Name]. All rights reserved.</p>
      <div style="display:flex; gap:1.5rem;">
        <a href="/privacy-policy" class="footer-bottom-link">Privacy Policy</a>
        <a href="/terms" class="footer-bottom-link">Terms of Service</a>
      </div>
    </div>
  </div>

</footer>

<style>
.footer-heading {
  font-size: 0.65rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-weight: 700;
  color: var(--color-accent-500);
  margin-bottom: 1rem;
}
.footer-link {
  display: block;
  font-size: 0.875rem;
  color: rgba(255,255,255,0.6);
  transition: color var(--duration-fast);
  padding: 0.1rem 0;
}
.footer-link:hover { color: var(--color-white); }

.footer-contact-item {
  display: flex;
  align-items: flex-start;
  gap: 0.6rem;
  color: rgba(255,255,255,0.65);
  transition: color var(--duration-fast);
  line-height: 1.5;
}
a.footer-contact-item:hover { color: var(--color-accent-300); }

.footer-social {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background-color: rgba(255,255,255,0.07);
  color: rgba(255,255,255,0.7);
  transition: background-color var(--duration-fast), color var(--duration-fast);
}
.footer-social:hover {
  background-color: var(--color-accent-500);
  color: var(--color-primary-900);
}

.footer-bottom-link {
  color: rgba(255,255,255,0.4);
  transition: color var(--duration-fast);
}
.footer-bottom-link:hover { color: rgba(255,255,255,0.8); }
</style>
