---
const testimonials = [
  {
    name: 'Sarah M.',
    project: 'Kitchen Renovation',
    location: '[City]',
    rating: 5,
    quote: 'Absolutely stunning results. They transformed our outdated kitchen into a modern masterpiece. The team was professional, clean, and completed everything on time. Highly recommend!',
  },
  {
    name: 'David & Karen L.',
    project: 'Roof Replacement',
    location: '[City]',
    rating: 5,
    quote: 'After getting 3 quotes, we chose this team for their transparent pricing and excellent reviews. Best decision we made. Our new roof looks incredible and was done in just 2 days.',
  },
  {
    name: 'James T.',
    project: 'Basement Renovation',
    location: '[City]',
    rating: 5,
    quote: 'They converted our unfinished basement into a beautiful living space. The craftsmanship is exceptional. The project came in on budget and we couldn\'t be happier with the outcome.',
  },
  {
    name: 'Michelle B.',
    project: 'Bathroom Renovation',
    location: '[City]',
    rating: 5,
    quote: 'My bathroom is now a spa retreat! Every detail was handled perfectly. The tile work is flawless. I\'ve already referred three neighbours — everyone has been equally thrilled.',
  },
];
---

<section class="section section-light" id="testimonials">
  <div class="container">

    <div class="testimonials-header fade-up">
      <span class="eyebrow">Client Reviews</span>
      <h2>What Our Clients Say</h2>
      <div class="gold-rule"></div>
      <div class="google-badge" aria-label="Google verified reviews">
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        <span style="font-size:0.78rem; font-weight:600; color:var(--color-gray-800);">Google Verified Reviews</span>
        <span style="font-size:0.78rem; color:var(--color-accent-700);">★ 4.9 / 5</span>
      </div>
    </div>

    <!-- Carousel track -->
    <div class="carousel" role="region" aria-label="Customer testimonials" aria-roledescription="carousel">
      <div class="carousel-track" id="testimonial-track">
        {testimonials.map((t, i) => (
          <div
            class="testimonial-card fade-up"
            role="group"
            aria-label={`Testimonial ${i + 1} of ${testimonials.length}`}
            aria-roledescription="slide"
          >
            <div class="testimonial-stars" aria-label={`${t.rating} out of 5 stars`}>
              {'★'.repeat(t.rating)}
            </div>
            <blockquote>
              <p style="color:var(--color-gray-800); line-height:var(--leading-relaxed); font-size:var(--text-base); font-style:italic; margin-bottom:1.5rem;">"{t.quote}"</p>
            </blockquote>
            <div style="display:flex; align-items:center; gap:0.75rem;">
              <div style="width:40px; height:40px; border-radius:50%; background:var(--color-primary-700); display:flex; align-items:center; justify-content:center; color:white; font-weight:600; font-size:0.9rem; flex-shrink:0;">
                {t.name.charAt(0)}
              </div>
              <div>
                <p style="font-weight:600; font-size:0.9rem; color:var(--color-text);">{t.name}</p>
                <p style="font-size:0.78rem; color:var(--color-gray-600);">{t.project} · {t.location}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Navigation -->
      <div class="carousel-nav" aria-label="Carousel navigation">
        <button class="carousel-btn" id="prev-btn" aria-label="Previous testimonial" type="button">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="carousel-dots" id="carousel-dots" role="tablist" aria-label="Testimonial navigation">
          {testimonials.map((_, i) => (
            <button
              class:list={['carousel-dot', { active: i === 0 }]}
              aria-label={`Go to testimonial ${i + 1}`}
              aria-selected={i === 0}
              role="tab"
              type="button"
              data-index={i}
            />
          ))}
        </div>
        <button class="carousel-btn" id="next-btn" aria-label="Next testimonial" type="button">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>

  </div>
</section>

<style>
.testimonials-header {
  margin-bottom: 3rem;
}

.google-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.4rem 1rem;
  background: var(--color-white);
  border-radius: var(--radius-full);
  border: 1px solid var(--color-gray-200);
  box-shadow: var(--shadow-sm);
  margin-top: 1rem;
}

.carousel {
  position: relative;
  overflow: hidden;
}

.carousel-track {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  transition: transform var(--duration-slow) var(--ease-out);
}

.carousel-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  margin-top: 2.5rem;
}

.carousel-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 2px solid var(--color-gray-200);
  color: var(--color-gray-800);
  transition: all var(--duration-fast);
}
.carousel-btn:hover {
  border-color: var(--color-accent-500);
  color: var(--color-accent-700);
  background-color: var(--color-accent-100);
}

.carousel-dots {
  display: flex;
  gap: 0.5rem;
}

.carousel-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background-color: var(--color-gray-300, #d1d5db);
  transition: all var(--duration-normal);
  border: none;
}
.carousel-dot.active {
  background-color: var(--color-accent-500);
  width: 24px;
  border-radius: var(--radius-full);
}

@media (max-width: 1023px) {
  .carousel-track { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 639px) {
  .carousel-track { grid-template-columns: 1fr; }
}
</style>

<script>
  const track = document.getElementById('testimonial-track');
  const dots = document.querySelectorAll('.carousel-dot');
  const cards = track?.querySelectorAll('.testimonial-card');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');

  if (!track || !cards) {
    // fallback if elements not found
  } else {
    let current = 0;
    const total = cards.length;

    function getVisible(): number {
      if (window.innerWidth >= 1024) return 3;
      if (window.innerWidth >= 640) return 2;
      return 1;
    }

    function go(index: number) {
      const visible = getVisible();
      const max = total - visible;
      current = Math.max(0, Math.min(index, max));

      const cardWidth = (track as HTMLElement).offsetWidth / visible;
      (track as HTMLElement).style.transform = `translateX(-${current * (cardWidth + 24)}px)`;

      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === current);
        dot.setAttribute('aria-selected', String(i === current));
      });
    }

    prevBtn?.addEventListener('click', () => go(current - 1));
    nextBtn?.addEventListener('click', () => go(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => go(i)));

    // Auto-slide every 5 seconds
    let autoSlide = setInterval(() => go(current + 1 >= total - getVisible() + 1 ? 0 : current + 1), 5000);
    track.addEventListener('mouseenter', () => clearInterval(autoSlide));
    track.addEventListener('mouseleave', () => {
      autoSlide = setInterval(() => go(current + 1 >= total - getVisible() + 1 ? 0 : current + 1), 5000);
    });
  }
</script>
