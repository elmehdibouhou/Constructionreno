---
const projects = [
  {
    title: 'Modern Open-Concept Kitchen',
    category: 'Kitchen · Renovation',
    img: '/images/projects/modern-open-concept-kitchen/hero.png',
    alt: 'Modern open-concept kitchen renovation Ontario',
    href: '/our-work/modern-open-concept-kitchen',
    large: true,
  },
  {
    title: 'Spa-Style Primary Ensuite',
    category: 'Bathroom · Renovation',
    img: '/images/projects/spa-style-primary-ensuite/hero.png',
    alt: 'Spa-style primary ensuite bathroom Ontario',
    href: '/our-work/spa-style-primary-ensuite',
    large: false,
  },
  {
    title: 'Standing Seam Metal Roof',
    category: 'Roofing',
    img: '/images/projects/standing-seam-metal-roof/hero.png',
    alt: 'Standing seam metal roof installation Ontario',
    href: '/our-work/standing-seam-metal-roof',
    large: false,
  },
  {
    title: 'Legal Basement Apartment',
    category: 'Basement · Renovation',
    img: '/images/projects/legal-basement-apartment/hero.png',
    alt: 'Legal basement apartment conversion Ontario',
    href: '/our-work/legal-basement-apartment',
    large: false,
  },
  {
    title: 'Complete Exterior Transformation',
    category: 'Exterior Renovations',
    img: '/images/projects/complete-exterior-renovation/hero.png',
    alt: 'Complete exterior renovation Ontario',
    href: '/our-work/complete-exterior-renovation',
    large: false,
  },
];
---

<section class="section section-dark" id="our-work">
  <div class="container">

    <div class="work-header fade-up">
      <span class="eyebrow">Portfolio</span>
      <h2 style="color:var(--color-white);">Recent Projects</h2>
      <div class="gold-rule"></div>
    </div>

    <div class="work-grid">
      {projects.map((project) => (
        <a
          href={project.href}
          class:list={['work-item', { 'work-item--large': project.large }]}
          aria-label={`View project: ${project.title}`}
        >
          <div class="work-item-inner img-overlay">
            <img
              src={project.img}
              alt={project.alt}
              width={project.large ? 900 : 500}
              height={project.large ? 600 : 400}
              loading="lazy"
              decoding="async"
              style="width:100%; height:100%; object-fit:cover;"
            />
            <div class="work-item-label">
              <p class="work-item-category">{project.category}</p>
              <h3 class="work-item-title">{project.title}</h3>
              <span class="work-item-view">View Project →</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div style="text-align:center;" class="fade-up">
      <a href="/our-work" class="btn-outline" style="margin-top:2.5rem; display:inline-flex;">See All Our Work →</a>
    </div>

  </div>
</section>

<style>
.work-header {
  margin-bottom: 2.5rem;
}

.work-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  grid-template-rows: auto auto;
  gap: 1rem;
}

.work-item {
  display: block;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.work-item--large {
  grid-row: 1 / 3;
}

.work-item-inner {
  position: relative;
  width: 100%;
  height: 100%;
  min-height: 220px;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.work-item--large .work-item-inner {
  min-height: 460px;
}

.work-item-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 1.25rem;
  z-index: 2;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity var(--duration-normal) var(--ease-out),
              transform var(--duration-normal) var(--ease-out);
}
.work-item:hover .work-item-label {
  opacity: 1;
  transform: translateY(0);
}

.work-item-category {
  font-size: 0.65rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-accent-300);
  font-weight: 600;
  margin-bottom: 0.25rem;
}

.work-item-title {
  font-family: var(--font-body);
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-white);
  margin-bottom: 0.35rem;
}

.work-item-view {
  font-size: 0.78rem;
  color: var(--color-accent-300);
  font-weight: 500;
  letter-spacing: 0.04em;
}

@media (max-width: 1023px) {
  .work-grid {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto;
  }
  .work-item--large { grid-row: auto; grid-column: 1 / 3; }
  .work-item--large .work-item-inner { min-height: 320px; }
}

@media (max-width: 639px) {
  .work-grid {
    grid-template-columns: 1fr;
  }
  .work-item--large { grid-column: 1; }
}
</style>
