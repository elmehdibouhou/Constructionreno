---
const services = [
  {
    title: 'Kitchen Renovation',
    href: '/services/kitchen-renovation',
    category: 'Renovation',
    img: 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&q=75',
    alt: 'Modern kitchen renovation',
  },
  {
    title: 'Bathroom Renovation',
    href: '/services/bathroom-renovation',
    category: 'Renovation',
    img: 'https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?w=800&q=75',
    alt: 'Luxury bathroom renovation',
  },
  {
    title: 'Basement Renovation',
    href: '/services/basement-renovation',
    category: 'Renovation',
    img: 'https://images.unsplash.com/photo-1565538810643-b5bdb714032a?w=800&q=75',
    alt: 'Finished basement renovation',
  },
  {
    title: 'Interior & Exterior Painting',
    href: '/services/painting',
    category: 'Renovation',
    img: 'https://images.unsplash.com/photo-1562259949-e8e7689d7828?w=800&q=75',
    alt: 'Professional interior painting',
  },
  {
    title: 'Roof Replacement',
    href: '/services/roof-replacement',
    category: 'Roofing',
    img: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&q=75',
    alt: 'Roof replacement installation',
  },
  {
    title: 'Metal Roofing',
    href: '/services/metal-roofing',
    category: 'Roofing',
    img: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=800&q=75',
    alt: 'Metal roofing installation',
  },
  {
    title: 'Exterior Siding',
    href: '/services/siding',
    category: 'Roofing',
    img: 'https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=800&q=75',
    alt: 'Exterior siding installation',
  },
  {
    title: 'Custom Homes',
    href: '/services/custom-homes',
    category: 'Construction',
    img: 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&q=75',
    alt: 'Custom home construction',
  },
];
---

<section class="section section-light" id="services">
  <div class="container">

    <div class="section-header fade-up">
      <span class="eyebrow">What We Do</span>
      <h2>Everything Your Home Needs</h2>
      <div class="gold-rule"></div>
      <p style="color:var(--color-gray-800); max-width:560px; font-size:var(--text-lg); line-height:var(--leading-relaxed);">
        From kitchen renovations to full roof replacements — expert craftsmanship on every project, backed by a 5-year workmanship warranty.
      </p>
    </div>

    <div class="services-grid">
      {services.map((service) => (
        <a href={service.href} class="service-card card-3d-wrapper" aria-label={service.title}>
          <div class="service-card-inner card-3d">
            <div class="img-overlay" style="aspect-ratio:1; border-radius:var(--radius-md); overflow:hidden;">
              <img
                src={service.img}
                alt={service.alt}
                width="400"
                height="400"
                loading="lazy"
                decoding="async"
                style="width:100%; height:100%; object-fit:cover;"
              />
            </div>
            <div class="service-card-content">
              <p class="service-card-category">{service.category}</p>
              <h3 class="service-card-title">{service.title}</h3>
              <span class="service-card-arrow" aria-hidden="true">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="section-cta fade-up">
      <a href="/services" class="btn-ghost">View All 16 Services →</a>
    </div>

  </div>
</section>

<style>
.section-header {
  margin-bottom: 3rem;
  max-width: 600px;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.25rem;
  margin-bottom: 3rem;
}

.service-card {
  display: block;
  text-decoration: none;
  color: inherit;
}

.service-card-inner {
  position: relative;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: box-shadow var(--duration-normal) var(--ease-out);
}
.service-card:hover .service-card-inner {
  box-shadow: var(--shadow-lg);
}

.service-card-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 1.5rem 1.25rem 1.25rem;
  background: linear-gradient(to top, rgba(10,30,42,0.95) 0%, rgba(10,30,42,0.4) 70%, transparent 100%);
  color: white;
  transform: translateZ(12px); /* slight 3D lift */
}

.service-card-category {
  font-size: 0.65rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-accent-300);
  font-weight: 600;
  margin-bottom: 0.25rem;
}

.service-card-title {
  font-family: var(--font-body);
  font-size: 1rem;
  font-weight: 600;
  line-height: 1.3;
  color: var(--color-white);
  margin-bottom: 0.5rem;
}

.service-card-arrow {
  display: inline-block;
  font-size: 1rem;
  color: var(--color-accent-300);
  opacity: 0;
  transform: translateX(-6px);
  transition: opacity var(--duration-normal), transform var(--duration-normal) var(--ease-out);
}
.service-card:hover .service-card-arrow {
  opacity: 1;
  transform: translateX(0);
}

.section-cta {
  text-align: center;
}

@media (max-width: 1023px) {
  .services-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 639px) {
  .services-grid { grid-template-columns: 1fr; }
}
</style>
