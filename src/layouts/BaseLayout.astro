---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  schema?: object | object[];
  noIndex?: boolean;
  tinaSetup?: { id: string; query: string; variables: unknown; data: unknown };
}

const {
  title = "Top Design Renovation | Renovation & Roofing in Ontario, Canada",
  description = "Expert renovation, roofing & construction in Ontario. Free estimates. Kitchen, bathroom, basement, painting & more. Call (613) 698-1654.",
  ogImage = "/Assets/og-image-1200x630.svg",
  canonical,
  schema,
  noIndex = false,
  tinaSetup,
} = Astro.props;

const siteUrl = "https://topdesignrenovation.ca";
const currentUrl = canonical || `${siteUrl}${Astro.url.pathname}`;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Top Design Renovation",
  "url": siteUrl,
  "logo": `${siteUrl}/Assets/logo-01-primary-dark.svg`,
  "image": [
    `${siteUrl}/Assets/og-image-1200x630.svg`,
    `${siteUrl}/Assets/logo-01-primary-dark.svg`
  ],
  "description": "Expert renovation, roofing & construction contractor serving Ontario and surrounding areas. Specializing in kitchen, bathroom, basement, roofing, painting, and full home renovations. Free estimates.",
  "telephone": "(613) 698-1654",
  "email": "info@topdesignrenovation.ca",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "274 Billrian Crescent",
    "addressLocality": "Stittsville",
    "addressRegion": "Ontario",
    "postalCode": "K2S 3A5",
    "addressCountry": "CA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 45.2627,
    "longitude": -75.9204
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "08:00",
      "closes": "17:00"
    }
  ],
  "priceRange": "$$",
  "areaServed": { "@type": "AdministrativeArea", "name": "Ontario" },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "100",
    "bestRating": "5",
    "worstRating": "1"
  },
  "sameAs": [
    "https://www.facebook.com/topdesignrenovation",
    "https://www.instagram.com/topdesignrenovation"
  ]
};
---

<!DOCTYPE html>
<html lang="en-CA">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={currentUrl} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta property="og:url" content={currentUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="en_CA" />
  <meta property="og:site_name" content="Top Design Renovation" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

  <!-- Fonts — preconnect for performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap"
  />

  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href="/Assets/logo-07-favicon-64px.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#1B3A4B" />

  <!-- Base Organization schema — every page -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <!-- Page-specific schema (optional — single object or array) -->
  {schema && (Array.isArray(schema) ? schema : [schema]).map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  <!-- Tina CMS visual editing setup (only active when in /admin iframe) -->
  {tinaSetup && (
    <script type="application/json" id="__tina_setup" set:html={JSON.stringify(tinaSetup)} />
  )}

  <!-- Google Analytics 4 — replace G-XXXXXXXXXX -->
  <!--
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-XXXXXXXXXX');
  </script>
  -->
</head>

<body>
  <!-- Skip to content (WCAG 2.1 AA) -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <Header />

  <main id="main-content">
    <slot />
  </main>

  <Footer />

  <!-- Scroll fade-in observer -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
  </script>

  <!-- Tina CMS visual editing runtime (activates click-to-edit + live preview in /admin iframe) -->
  <script>
    const __tinaEl = document.getElementById('__tina_setup');
    if (__tinaEl) {
      const setup = JSON.parse(__tinaEl.textContent || '{}');

      // Register this document's form with the Tina admin parent
      parent.postMessage({ type: 'open', ...setup }, '*');
      parent.postMessage({ type: 'url-changed' }, '*');

      // Navigate a dot-separated path inside an object
      function getByPath(obj, pathStr) {
        return pathStr.split('.').reduce(function(acc, key) {
          return acc != null ? acc[key] : undefined;
        }, obj);
      }

      // Apply live data received from the admin panel to the DOM
      function applyUpdate(newData) {
        document.querySelectorAll('[data-tina-field]').forEach(function(el) {
          var attr = el.getAttribute('data-tina-field');
          if (!attr) return;
          var hashIdx = attr.indexOf('#');
          if (hashIdx === -1) return;
          if (attr.slice(0, hashIdx) !== setup.id) return;
          var value = getByPath(newData, attr.slice(hashIdx + 1));
          if (value == null || typeof value !== 'string') return;
          if (el.tagName === 'IMG') {
            el.setAttribute('src', value);
          } else if (el.childElementCount === 0) {
            el.textContent = value;
          }
        });
      }

      // Listen for admin messages
      window.addEventListener('message', function(e) {
        if (!e.data || typeof e.data !== 'object') return;

        // Live content update — Tina sends { id, data } (no type field)
        if (e.data.id === setup.id && e.data.data !== undefined) {
          applyUpdate(e.data.data);
        }

        // Admin enables click-to-edit mode
        if (e.data.type === 'quickEditEnabled' && e.data.value) {
          var style = document.createElement('style');
          style.textContent = [
            '[data-tina-field]{outline:2px dashed rgba(34,150,254,.5);transition:box-shadow .15s,outline .15s}',
            '[data-tina-field]:hover{outline:2px solid rgba(34,150,254,1);cursor:pointer;box-shadow:inset 100vi 100vh rgba(34,150,254,.3)}',
          ].join('');
          document.head.appendChild(style);

          // Click handler — send selected field to admin
          document.addEventListener('click', function(ev) {
            var target = ev.target.closest('[data-tina-field]');
            if (target) {
              ev.preventDefault();
              ev.stopPropagation();
              var fieldName = target.getAttribute('data-tina-field');
              if (fieldName) {
                parent.postMessage({ type: 'field:selected', fieldName }, '*');
              }
            }
          }, true);

          // Notify admin whether this page has tina fields
          var hasFields = !!document.querySelector('[data-tina-field]');
          parent.postMessage({ type: 'quick-edit', value: hasFields }, '*');
        }
      });
    }
  </script>
</body>
</html>
