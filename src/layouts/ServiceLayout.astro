---
import { tinaField } from 'tinacms/dist/react';
import BaseLayout from './BaseLayout.astro';
import BreadcrumbNav from '../components/ui/BreadcrumbNav.astro';
import FAQ from '../components/ui/FAQ.astro';
import ContactForm from '../components/ui/ContactForm.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';

interface Props {
  service: any;
  relatedServices: any[];
  tinaSetup?: any;
}

const { service, relatedServices = [], tinaSetup } = Astro.props;

function toEmbedUrl(url: string): string | null {
  if (!url) return null;
  const yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([A-Za-z0-9_-]{11})/);
  if (yt) return `https://www.youtube.com/embed/${yt[1]}?rel=0&autoplay=1`;
  const vm = url.match(/vimeo\.com\/(\d+)/);
  if (vm) return `https://player.vimeo.com/video/${vm[1]}?autoplay=1`;
  return null;
}

function getYoutubeThumbnail(url: string): string | null {
  const yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([A-Za-z0-9_-]{11})/);
  return yt ? `https://img.youtube.com/vi/${yt[1]}/hqdefault.jpg` : null;
}

function isDirectVideo(url: string): boolean {
  return /\.(mp4|webm|ogg)(\?.*)?$/i.test(url);
}

const embedUrl = service.videoUrl ? toEmbedUrl(service.videoUrl) : null;

interface GalleryItem {
  src: string;
  alt: string;
  videoUrl: string;
  embedUrl: string;
  isVideo: boolean;
  isDirect: boolean;
}

const galleryItems: GalleryItem[] = (service.gallery ?? []).map((item: any, i: number) => {
  const raw = typeof item === 'string' ? { src: item, alt: '', videoUrl: '' } : item;
  const src: string = raw.src ?? '';
  const alt: string = raw.alt || `${service.title} — media ${i + 1}`;
  const videoUrl: string = raw.videoUrl ?? '';

  let thumbnail = src;
  let embed = '';
  let isDirect = false;

  if (videoUrl) {
    const ytThumb = getYoutubeThumbnail(videoUrl);
    if (ytThumb && !thumbnail) thumbnail = ytThumb;
    embed = toEmbedUrl(videoUrl) ?? '';
    isDirect = !embed && isDirectVideo(videoUrl);
    if (isDirect) embed = videoUrl;
  }

  return { src: thumbnail, alt, videoUrl, embedUrl: embed, isVideo: !!videoUrl, isDirect };
}).filter((g: GalleryItem) => g.src || g.videoUrl);

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": service.title,
  "provider": {
    "@type": "HomeAndConstructionBusiness",
    "name": "Top Design Renovation",
    "url": "https://topdesignrenovation.ca"
  },
  "areaServed": { "@type": "AdministrativeArea", "name": "Ontario" },
  "description": service.metaDesc,
  "offers": {
    "@type": "Offer",
    "priceCurrency": "CAD",
    "description": "Free estimate — no obligation"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": (service.faqs ?? []).map((f: any) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://topdesignrenovation.ca" },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://topdesignrenovation.ca/services" },
    { "@type": "ListItem", "position": 3, "name": service.title }
  ]
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": `How to Get ${service.title} in Ontario`,
  "description": `Step-by-step process to get professional ${service.title} service from Top Design Renovation in Ontario.`,
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Request a Free Estimate",
      "text": "Fill out our online form or call (613) 698-1654. We respond within 1 business day.",
      "url": "https://topdesignrenovation.ca/free-estimate"
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "On-Site Assessment",
      "text": "Our team visits your property to assess the scope of work and take measurements."
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Receive a Written Quote",
      "text": "You get a detailed written quote within 3-5 business days — no hidden fees, no pressure."
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "Project Execution",
      "text": "Our licensed team completes the work on schedule, backed by a 5-year workmanship warranty."
    }
  ]
};

const specialistSchema = service.category === 'Electrical' ? {
  "@context": "https://schema.org",
  "@type": "Electrician",
  "name": "Top Design Renovation",
  "url": "https://topdesignrenovation.ca",
  "telephone": "(613) 698-1654",
  "areaServed": { "@type": "AdministrativeArea", "name": "Ontario" },
  "description": service.metaDesc,
} : service.category === 'Plumbing' ? {
  "@context": "https://schema.org",
  "@type": "Plumber",
  "name": "Top Design Renovation",
  "url": "https://topdesignrenovation.ca",
  "telephone": "(613) 698-1654",
  "areaServed": { "@type": "AdministrativeArea", "name": "Ontario" },
  "description": service.metaDesc,
} : null;

// Lucide-style inline SVG icons
const icons: Record<string, string> = {
  layout: '<path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z"/>',
  star: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  droplets: '<path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0014 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 01-11.91 4.97"/>',
  tool: '<path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>',
  zap: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  home: '<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  "dollar-sign": '<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>',
  "check-circle": '<polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>',
  palette: '<circle cx="13.5" cy="6.5" r=".5"/><circle cx="17.5" cy="10.5" r=".5"/><circle cx="8.5" cy="7.5" r=".5"/><circle cx="6.5" cy="12.5" r=".5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 011.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/>',
  "check-square": '<polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>',
  sun: '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>',
  maximize: '<polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>',
  "trending-up": '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>',
  layers: '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
  clock: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  "cloud-snow": '<path d="M20 17.58A5 5 0 0018 8h-1.26A8 8 0 104 15.25"/><line x1="8" y1="16" x2="8.01" y2="16"/><line x1="8" y1="20" x2="8.01" y2="20"/><line x1="12" y1="18" x2="12.01" y2="18"/><line x1="12" y1="22" x2="12.01" y2="22"/><line x1="16" y1="16" x2="16.01" y2="16"/><line x1="16" y1="20" x2="16.01" y2="20"/>',
  thermometer: '<path d="M14 14.76V3.5a2.5 2.5 0 00-5 0v11.26a4.5 4.5 0 105 0z"/>',
  wind: '<path d="M9.59 4.59A2 2 0 1111 8H2m10.59 11.41A2 2 0 1014 16H2m15.73-8.27A2.5 2.5 0 1119.5 12H2"/>',
  edit: '<path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>',
  "shield-check": '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>',
  leaf: '<path d="M2 22l10-10M13 2s0 8-8 13c0 0 7 1 12-5 2.64-3.18 2.64-8 2.64-8H13z"/>',
  "file-text": '<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>',
  search: '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>',
  calendar: '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>',
};
---

<BaseLayout
  title={service.metaTitle}
  description={service.metaDesc}
  schema={[serviceSchema, breadcrumbSchema, howToSchema]}
  tinaSetup={tinaSetup}
>
  <!-- Hero -->
  <section
    class="service-hero"
    style={`background-image: url('${service.heroImg}');`}
    aria-labelledby="service-h1"
  >
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="container service-hero-content">
      <BreadcrumbNav crumbs={[
        { label: 'Home', href: '/' },
        { label: 'Services', href: '/services' },
        { label: service.title },
      ]} />
      <h1 id="service-h1" style="color:white; margin-top:1rem; max-width:700px;"><span data-tina-field={tinaField(service, 'title')}>{service.title}</span> in Ottawa</h1>
      <p style="color:rgba(255,255,255,0.85); font-size:var(--text-lg); max-width:560px; margin:1rem 0 2rem;" data-tina-field={tinaField(service, 'tagline')}>
        {service.tagline}
      </p>
      <a href="/free-estimate" class="btn-primary">Get a Free Estimate →</a>
    </div>
  </section>

  <!-- Intro + Why Choose Us -->
  <section class="section">
    <div class="container">
      <div class="service-intro-grid">
        <div>
          <span class="eyebrow">About This Service</span>
          <h2 style="margin-bottom:1rem;">About Our {service.title} Services</h2>
          <div class="gold-rule"></div>
          <p class="body-lg" style="color:var(--color-gray-800); margin-bottom:1.25rem;" data-tina-field={tinaField(service, 'intro1')}>{service.intro1}</p>
          <p style="color:var(--color-gray-800);" data-tina-field={tinaField(service, 'intro2')}>{service.intro2}</p>
        </div>
        <div class="why-us-card">
          <h3 style="color:var(--color-white); margin-bottom:1.25rem;">Why Choose Us?</h3>
          <ul style="list-style:none; display:flex; flex-direction:column; gap:0.85rem;">
            {service.whyUs.map(item => (
              <li style="display:flex; align-items:flex-start; gap:0.75rem; color:rgba(255,255,255,0.85); font-size:0.9rem; line-height:1.5;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="color:var(--color-accent-500); flex-shrink:0; margin-top:1px;" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
          <div style="margin-top:2rem;">
            <a href="/free-estimate" class="btn-primary" style="font-size:0.78rem; padding:0.65rem 1.5rem;">Free Estimate →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits (3 cards) -->
  <section class="section section-light">
    <div class="container">
      <div class="benefits-grid">
        {service.benefits.map(b => (
          <div class="benefit-card fade-up">
            <div class="benefit-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[b.icon] ?? icons.star} />
            </div>
            <h3 class="benefit-title">{b.title}</h3>
            <p style="color:var(--color-gray-800); line-height:var(--leading-relaxed);">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Video (optional) -->
  {embedUrl && (
    <section class="section section-light">
      <div class="container container--narrow">
        <span class="eyebrow">Watch & Learn</span>
        <h2 style="margin-bottom:2rem;">{service.title} — See Our Work in Action</h2>
        <div class="video-wrapper">
          <iframe
            src={embedUrl}
            title={`${service.title} video`}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </section>
  )}

  <!-- Gallery -->
  {galleryItems.length > 0 && (
    <section class="section">
      <div class="container">
        <span class="eyebrow">Our Work</span>
        <h2 style="margin-bottom:2rem;">Recent {service.title} Projects</h2>
        <div class="service-gallery">
          {galleryItems.map((item) => (
            <div class:list={['gallery-item', 'img-overlay', item.isVideo ? 'gallery-item--video' : '']}>
              {item.isVideo ? (
                <button
                  class="gallery-video-btn"
                  data-embed={item.embedUrl}
                  data-direct={item.isDirect ? 'true' : 'false'}
                  aria-label={`Lire la vidéo : ${item.alt}`}
                  type="button"
                >
                  {item.src && (
                    <img
                      src={item.src}
                      alt={item.alt}
                      width="600"
                      height="450"
                      loading="lazy"
                      decoding="async"
                      style="width:100%; height:100%; object-fit:cover;"
                    />
                  )}
                  <span class="play-btn" aria-hidden="true">
                    <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
                      <circle cx="26" cy="26" r="26" fill="rgba(0,0,0,0.55)"/>
                      <polygon points="21,17 39,26 21,35" fill="white"/>
                    </svg>
                  </span>
                </button>
              ) : (
                <img
                  src={item.src}
                  alt={item.alt}
                  width="600"
                  height="450"
                  loading="lazy"
                  decoding="async"
                  style="width:100%; height:100%; object-fit:cover;"
                />
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Video modal -->
  <div id="gallery-modal" class="gallery-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Lecteur vidéo">
    <div class="gallery-modal-backdrop"></div>
    <div class="gallery-modal-inner">
      <button class="gallery-modal-close" aria-label="Fermer" type="button">✕</button>
      <div class="gallery-modal-player" id="gallery-modal-player"></div>
    </div>
  </div>

  <!-- FAQ -->
  <section class="section section-light" aria-labelledby="faq-heading">
    <div class="container container--narrow">
      <span class="eyebrow">Questions & Answers</span>
      <h2 id="faq-heading" style="margin-bottom:0.75rem;">{service.title} FAQ</h2>
      <div class="gold-rule"></div>
      <FAQ items={service.faqs} />
    </div>

    <!-- FAQ schema -->
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

    <!-- Specialist schema (Electrician / Plumber) -->
    {specialistSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(specialistSchema)} />
    )}
  </section>

  <!-- Contact Form + Info split -->
  <section class="section section-dark" aria-labelledby="contact-heading">
    <div class="container">
      <div class="service-contact-grid">
        <div>
          <span class="eyebrow" style="color:var(--color-accent-300);">Request a Quote</span>
          <h2 id="contact-heading" style="color:white; margin-bottom:0.75rem;">Get a Free {service.title} Estimate</h2>
          <div class="gold-rule"></div>
          <p style="color:rgba(255,255,255,0.7); margin-bottom:2rem; line-height:var(--leading-relaxed);">
            Fill out the form and we'll get back to you within 1 business day with a detailed written quote.
          </p>
          <ContactForm dark={true} />
        </div>
        <div class="contact-info-col">
          <div class="contact-info-card">
            <h3 style="color:var(--color-accent-300); margin-bottom:1.5rem;">Contact Information</h3>
            <div class="contact-info-items">
              <a href="tel:+16136981654" class="contact-info-item">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.12 1.18 2 2 0 012.11 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                <div>
                  <p style="font-size:0.75rem; color:var(--color-accent-500); text-transform:uppercase; letter-spacing:0.1em; font-weight:600; margin-bottom:0.2rem;">Phone</p>
                  <p style="color:white; font-weight:500;">(613) 698-1654</p>
                </div>
              </a>
              <a href="mailto:info@topdesignrenovation.ca" class="contact-info-item">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <div>
                  <p style="font-size:0.75rem; color:var(--color-accent-500); text-transform:uppercase; letter-spacing:0.1em; font-weight:600; margin-bottom:0.2rem;">Email</p>
                  <p style="color:white; font-weight:500;">info@topdesignrenovation.ca</p>
                </div>
              </a>
              <div class="contact-info-item" style="cursor:default;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <div>
                  <p style="font-size:0.75rem; color:var(--color-accent-500); text-transform:uppercase; letter-spacing:0.1em; font-weight:600; margin-bottom:0.2rem;">Hours</p>
                  <p style="color:rgba(255,255,255,0.8);">Mon–Fri: 8:00am – 5:00pm</p>
                </div>
              </div>
            </div>
            <div style="margin-top:2rem; padding:1.25rem; background:rgba(200,169,110,0.1); border-radius:var(--radius-md); border:1px solid rgba(200,169,110,0.2);">
              <p style="font-size:0.85rem; color:rgba(255,255,255,0.75); line-height:1.6;">
                <strong style="color:var(--color-accent-300);">Free estimates always.</strong> We provide written quotes with no hidden fees, no pressure, and no obligation.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  {relatedServices.length > 0 && (
    <section class="section section-light">
      <div class="container">
        <h2 style="margin-bottom:2rem;">You May Also Be Interested In</h2>
        <div class="related-grid">
          {relatedServices.map((rs: any) => (
            <a href={`/services/${rs.slug}`} class="related-card img-overlay">
              <img
                src={rs.cardImg}
                alt={rs.alt}
                width="500"
                height="320"
                loading="lazy"
                decoding="async"
                style="width:100%; height:100%; object-fit:cover;"
              />
              <div class="related-label">
                <p style="font-size:0.65rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-accent-300); font-weight:600; margin-bottom:0.25rem;">{rs.category}</p>
                <p style="font-weight:600; color:white;">{rs.title}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Banner -->
  <CtaBanner
    heading={`Ready to Start Your ${service.title}?`}
    subtext="Get your free estimate today. No obligation, no pressure — just honest advice from experienced tradespeople."
  />

</BaseLayout>

<style>
/* Hero */
.service-hero {
  position: relative;
  background-size: cover;
  background-position: center;
  min-height: 60vh;
  display: flex;
  align-items: flex-end;
  padding-bottom: 4rem;
}
.service-hero-content {
  position: relative;
  z-index: 1;
  padding-top: 6rem;
}

/* Intro grid */
.service-intro-grid {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 4rem;
  align-items: start;
}
.why-us-card {
  background: var(--color-primary-800);
  border-radius: var(--radius-lg);
  padding: 2rem;
  border-left: 3px solid var(--color-accent-500);
  position: sticky;
  top: 120px;
}

/* Benefits */
.benefits-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}
.benefit-card {
  text-align: center;
  padding: 2rem 1.5rem;
  background: white;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  border: 1px solid var(--color-gray-100);
}
.benefit-icon {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: var(--color-accent-100);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 1.25rem;
  color: var(--color-accent-700);
}
.benefit-title {
  font-size: var(--text-xl);
  margin-bottom: 0.75rem;
}

/* Video */
.video-wrapper {
  position: relative;
  padding-bottom: 56.25%;
  height: 0;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}
.video-wrapper iframe {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  border: 0;
}

/* Gallery */
.service-gallery {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}
.gallery-item {
  aspect-ratio: 4/3;
  border-radius: var(--radius-md);
  overflow: hidden;
  cursor: pointer;
}
.gallery-video-btn {
  display: block;
  position: relative;
  width: 100%;
  height: 100%;
  border: none;
  padding: 0;
  background: #0a1e2a;
  cursor: pointer;
}
.play-btn {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s ease;
}
.gallery-video-btn:hover .play-btn { transform: scale(1.12); }
.gallery-video-btn:hover img { opacity: 0.8; }
.gallery-video-btn img { transition: opacity 0.2s ease; }

/* Video modal */
.gallery-modal {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 9999;
  align-items: center;
  justify-content: center;
}
.gallery-modal.is-open { display: flex; }
.gallery-modal-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.88);
}
.gallery-modal-inner {
  position: relative;
  z-index: 1;
  width: min(900px, 94vw);
}
.gallery-modal-close {
  position: absolute;
  top: -2.5rem;
  right: 0;
  background: none;
  border: none;
  color: white;
  font-size: 1.5rem;
  cursor: pointer;
  line-height: 1;
  opacity: 0.8;
}
.gallery-modal-close:hover { opacity: 1; }
.gallery-modal-player {
  position: relative;
  padding-bottom: 56.25%;
  height: 0;
  background: #000;
  border-radius: var(--radius-md);
  overflow: hidden;
}
.gallery-modal-player iframe,
.gallery-modal-player video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: 0;
}

/* Contact */
.service-contact-grid {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 4rem;
  align-items: start;
}
.contact-info-card {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: var(--radius-lg);
  padding: 2rem;
  position: sticky;
  top: 120px;
}
.contact-info-items { display: flex; flex-direction: column; gap: 1.25rem; }
.contact-info-item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  color: var(--color-white);
  transition: opacity var(--duration-fast);
}
a.contact-info-item:hover { opacity: 0.85; }
.contact-info-item svg { color: var(--color-accent-500); flex-shrink: 0; margin-top: 2px; }

/* Related */
.related-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}
.related-card {
  display: block;
  aspect-ratio: 3/2;
  border-radius: var(--radius-md);
  overflow: hidden;
}
.related-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 1.25rem;
  z-index: 2;
}

/* Responsive */
@media (max-width: 1023px) {
  .service-intro-grid { grid-template-columns: 1fr; }
  .why-us-card { position: static; }
  .service-contact-grid { grid-template-columns: 1fr; }
  .contact-info-card { position: static; }
}
@media (max-width: 767px) {
  .benefits-grid { grid-template-columns: 1fr; }
  .service-gallery { grid-template-columns: repeat(2, 1fr); }
  .related-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 479px) {
  .service-gallery { grid-template-columns: 1fr; }
  .related-grid { grid-template-columns: 1fr; }
}
</style>

<script>
  const modal = document.getElementById('gallery-modal')!;
  const player = document.getElementById('gallery-modal-player')!;

  function openModal(embedUrl: string, isDirect: boolean) {
    player.innerHTML = isDirect
      ? `<video src="${embedUrl}" controls autoplay playsinline></video>`
      : `<iframe src="${embedUrl}" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>`;
    modal.classList.add('is-open');
    modal.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    player.innerHTML = '';
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLButtonElement>('.gallery-video-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const embed = btn.dataset.embed ?? '';
      const direct = btn.dataset.direct === 'true';
      if (embed) openModal(embed, direct);
    });
  });

  modal.querySelector('.gallery-modal-backdrop')?.addEventListener('click', closeModal);
  modal.querySelector('.gallery-modal-close')?.addEventListener('click', closeModal);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
