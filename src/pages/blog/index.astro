---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';

const posts = [
  {
    slug: 'basement-renovation-guide',
    title: 'Complete Guide to Basement Renovation in Canada (2026)',
    excerpt: 'Everything [City] homeowners need to know about finishing a basement — costs, timelines, permits, and design ideas to maximise your investment.',
    date: '2026-01-15',
    category: 'Renovation',
    readTime: '8 min',
    img: 'https://images.unsplash.com/photo-1565538810643-b5bdb714032a?w=800&q=75',
  },
  {
    slug: 'painting-trends-2026',
    title: 'Interior Painting Trends for 2026: What [City] Homeowners Are Choosing',
    excerpt: 'From warm terracottas to deep forest greens — the paint colours and techniques transforming [City] homes in 2026.',
    date: '2026-02-10',
    category: 'Design',
    readTime: '5 min',
    img: 'https://images.unsplash.com/photo-1562259949-e8e7689d7828?w=800&q=75',
  },
  {
    slug: 'choosing-renovation-contractor',
    title: 'How to Choose a Renovation Contractor in [Province]: 8 Things to Check',
    excerpt: 'Hiring the wrong contractor is one of the costliest mistakes a homeowner can make. Here\'s exactly what to verify before signing anything.',
    date: '2026-03-05',
    category: 'Tips',
    readTime: '6 min',
    img: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=800&q=75',
  },
];
---

<BaseLayout
  title="Blog | [Company Name] — Renovation & Roofing Tips for [City] Homeowners"
  description="Expert renovation and roofing tips, design trends, and homeowner guides from [Company Name] in [City], [Province]."
>

  <section
    style="background:linear-gradient(105deg,rgba(10,30,42,0.9) 0%,rgba(10,30,42,0.6) 100%),url('https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=1920&q=80') center/cover; padding-block:6rem 4rem;"
    aria-labelledby="blog-h1"
  >
    <div class="container" style="position:relative; z-index:1;">
      <span class="eyebrow">Expert Advice</span>
      <h1 id="blog-h1" style="color:white; max-width:600px; margin-bottom:1rem;">Renovation & Roofing Blog</h1>
      <p style="color:rgba(255,255,255,0.8); max-width:500px; font-size:var(--text-lg);">
        Tips, guides, and design ideas from our [City] renovation and roofing team.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="blog-index-grid">
        {posts.map((post, i) => (
          <article class:list={['blog-index-card', { 'blog-index-card--featured': i === 0 }]}>
            <a href={`/blog/${post.slug}`} class="blog-card-img img-overlay">
              <img
                src={post.img}
                alt={post.title}
                width={i === 0 ? 900 : 600}
                height={i === 0 ? 560 : 380}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
                style="width:100%; height:100%; object-fit:cover;"
              />
            </a>
            <div class="blog-card-body">
              <div class="blog-card-meta">
                <span class="blog-card-cat">{post.category}</span>
                <span style="color:var(--color-gray-400);">·</span>
                <time datetime={post.date} style="font-size:0.8rem; color:var(--color-gray-600);">
                  {new Date(post.date).toLocaleDateString('en-CA', { year:'numeric', month:'long', day:'numeric' })}
                </time>
                <span style="color:var(--color-gray-400);">·</span>
                <span style="font-size:0.8rem; color:var(--color-gray-600);">{post.readTime} read</span>
              </div>
              <h2 class="blog-card-title">
                <a href={`/blog/${post.slug}`}>{post.title}</a>
              </h2>
              <p class="blog-card-excerpt">{post.excerpt}</p>
              <a href={`/blog/${post.slug}`} class="blog-card-read-more">Read Article →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />

</BaseLayout>

<style>
.blog-index-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}
.blog-index-card--featured {
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
}
.blog-card-img {
  display: block;
  aspect-ratio: 16/10;
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.blog-index-card--featured .blog-card-img { aspect-ratio: 3/2; height: 100%; }
.blog-card-body { padding: 0.25rem 0; }
.blog-card-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; flex-wrap: wrap; }
.blog-card-cat {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-accent-700);
  background: var(--color-accent-100);
  padding: 0.2rem 0.6rem;
  border-radius: var(--radius-full);
}
.blog-card-title {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  font-weight: 400;
  line-height: 1.25;
  margin-bottom: 0.75rem;
  color: var(--color-primary-900);
}
.blog-card-title a { transition: color var(--duration-fast); }
.blog-card-title a:hover { color: var(--color-primary-600); }
.blog-index-card:not(.blog-index-card--featured) .blog-card-title { font-size: var(--text-2xl); }
.blog-card-excerpt { font-size: 0.9rem; color: var(--color-gray-800); line-height: 1.7; margin-bottom: 1.25rem; }
.blog-card-read-more { font-size: 0.82rem; font-weight: 600; color: var(--color-accent-700); transition: color var(--duration-fast); letter-spacing: 0.04em; }
.blog-card-read-more:hover { color: var(--color-accent-500); }
@media (max-width: 1023px) {
  .blog-index-card--featured { grid-template-columns: 1fr; grid-column: auto; }
  .blog-index-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 639px) { .blog-index-grid { grid-template-columns: 1fr; } }
</style>
