---
import { getCollection } from 'astro:content';
import { client } from '../../../tina/__generated__/client';
import { prepareTinaData, normalizeImgSrc } from '../../lib/tina-helper';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { slug: post.slug },
  }));
}

const { slug } = Astro.props;

// Content collections data (markdown files — always available)
const posts = await getCollection('blog');
const post = posts.find(p => p.slug === slug)!;
const { Content } = await post.render();

// Tina data with visual editing metadata (may fail if TinaCloud hasn't indexed schema yet)
let tinaSetup: any = null;
let tinaData: any = null;
try {
  const tinaResult = await client.queries.blog({ relativePath: `${slug}.md` });
  const prepared = prepareTinaData(tinaResult);
  tinaSetup = prepared.tinaSetup;
  tinaData = prepared.data.blog;
} catch {
  tinaData = { ...post.data, heroImg: normalizeImgSrc(post.data.heroImg) };
}
---

<BlogLayout
  tinaData={tinaData}
  tinaSetup={tinaSetup}
  title={tinaData.title}
  description={tinaData.description}
  pubDate={tinaData.pubDate}
  heroImg={tinaData.heroImg}
  heroAlt={tinaData.heroAlt ?? ''}
  category={tinaData.category}
  readTime={tinaData.readTime ?? ''}
  videoUrl={tinaData.videoUrl ?? ''}
  videoSection={tinaData.videoSection}
>
  <Content />
</BlogLayout>
