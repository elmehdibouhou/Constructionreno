---
import { getCollection } from 'astro:content';
import { client } from '../../../tina/__generated__/client';
import { prepareTinaData } from '../../lib/tina-helper';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { slug: post.slug },
  }));
}

const { slug } = Astro.props;

// Tina data with visual editing metadata
const tinaResult = await client.queries.blog({ relativePath: `${slug}.md` });
const { tinaSetup, data: tinaBlogData } = prepareTinaData(tinaResult);
const tinaData = tinaBlogData.blog;

// Render markdown body from Content Collections
const posts = await getCollection('blog');
const post = posts.find(p => p.slug === slug)!;
const { Content } = await post.render();
---

<BlogLayout
  tinaData={tinaData}
  tinaSetup={tinaSetup}
  title={tinaData.title}
  description={tinaData.description}
  pubDate={tinaData.pubDate}
  heroImg={tinaData.heroImg}
  heroAlt={tinaData.heroAlt ?? ''}
  category={tinaData.category}
  readTime={tinaData.readTime ?? ''}
  videoUrl={tinaData.videoUrl ?? ''}
  videoSection={tinaData.videoSection}
>
  <Content />
</BlogLayout>
