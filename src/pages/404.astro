---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | [Company Name]"
  description="The page you're looking for doesn't exist."
  noIndex={true}
>
  <section style="min-height:80vh; display:flex; align-items:center; background:var(--color-primary-900);">
    <div class="container" style="text-align:center; padding-block:4rem;">
      <p style="font-family:var(--font-display); font-size:clamp(6rem,20vw,12rem); font-weight:300; color:var(--color-accent-500); line-height:1; margin-bottom:0.5rem;">404</p>
      <h1 style="color:white; font-size:var(--text-4xl); margin-bottom:1rem;">Page Not Found</h1>
      <div class="gold-rule" style="margin-inline:auto;"></div>
      <p style="color:rgba(255,255,255,0.65); font-size:var(--text-lg); max-width:460px; margin:0 auto 2.5rem; line-height:var(--leading-relaxed);">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="/" class="btn-primary">Go to Homepage</a>
        <a href="/services" class="btn-outline">Our Services</a>
      </div>
    </div>
  </section>
</BaseLayout>
