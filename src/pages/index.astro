---
import { client } from '../../tina/__generated__/client';
import { prepareTinaData } from '../lib/tina-helper';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroHome from '../components/sections/HeroHome.astro';
import Stats from '../components/sections/Stats.astro';
import ServicesGrid from '../components/sections/ServicesGrid.astro';
import AboutTeaser from '../components/sections/AboutTeaser.astro';
import RecentWork from '../components/sections/RecentWork.astro';
import TestimonialSlider from '../components/sections/TestimonialSlider.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import FloatingCTA from '../components/ui/FloatingCTA.astro';

const homeResult = await client.queries.home({ relativePath: 'home.md' });
const { tinaSetup, data: tinaHomeData } = prepareTinaData(homeResult);
const homeData = tinaHomeData.home;
---

<BaseLayout
  title="Top Design Renovation | Renovation & Roofing in Ottawa, Canada"
  description="Expert renovation, roofing & construction in Ottawa. Free estimates on kitchen, bathroom & basement renovations, painting, roof replacements & more. Call (613) 698-1654."
  tinaSetup={tinaSetup}
>
  <HeroHome data={homeData} />
  <Stats />
  <ServicesGrid />
  <AboutTeaser data={homeData} />
  <RecentWork />
  <TestimonialSlider />
  <CtaBanner />
  <FloatingCTA />
</BaseLayout>
