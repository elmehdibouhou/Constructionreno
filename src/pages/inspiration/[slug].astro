---
import { getCollection } from 'astro:content';
import InspirationLayout from '../../layouts/InspirationLayout.astro';

export async function getStaticPaths() {
  const pages = await getCollection('inspiration');
  return pages.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<InspirationLayout page={entry.data} slug={entry.slug} />
