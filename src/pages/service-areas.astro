---
import BaseLayout from '../layouts/BaseLayout.astro';
import areaData from '../data/service-areas.json';
import CtaBanner from '../components/sections/CtaBanner.astro';
import services from '../data/services.json';
---

<BaseLayout
  title="Service Areas | [Company Name] — [City] & Surrounding Area"
  description="[Company Name] serves [City] and surrounding communities with renovation, roofing & construction services. View our full service area."
>

  <section
    style="background:linear-gradient(105deg,rgba(10,30,42,0.9) 0%,rgba(10,30,42,0.6) 100%),url('https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=1920&q=80') center/cover; padding-block:6rem 4rem;"
    aria-labelledby="areas-h1"
  >
    <div class="container" style="position:relative; z-index:1;">
      <span class="eyebrow">Where We Work</span>
      <h1 id="areas-h1" style="color:white; max-width:600px; margin-bottom:1rem;">Service Areas</h1>
      <p style="color:rgba(255,255,255,0.8); max-width:520px; font-size:var(--text-lg);">
        We serve {areaData.primary} and the surrounding {areaData.province} communities with renovation, roofing, and construction services.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="areas-layout">

        <div>
          <span class="eyebrow">Coverage Area</span>
          <h2 style="margin-bottom:0.75rem;">Where We Work</h2>
          <div class="gold-rule"></div>
          <p style="color:var(--color-gray-800); line-height:var(--leading-relaxed); margin-bottom:2rem; font-size:var(--text-lg);">
            Based in {areaData.primary}, {areaData.province}, we regularly serve clients within a 60 km radius. Don't see your community listed? Contact us — we may still be able to help.
          </p>

          <div class="areas-grid">
            {areaData.areas.map(area => (
              <div class="area-card">
                <div class="area-pin" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div>
                  <h3 class="area-name">{area.name}</h3>
                  <p class="area-desc">{area.description}</p>
                  <p class="area-distance">{area.distance} from base</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Map -->
        <div class="areas-map-col">
          <div class="map-embed">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2800.0!2d-75.6972!3d45.4215!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDXCsDI1JzE3LjQiTiA3NcKwNDEnNTAuMCJX!5e0!3m2!1sen!2sca!4v1"
              width="100%"
              height="100%"
              style="border:0; border-radius:var(--radius-lg);"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="[Company Name] service area"
            ></iframe>
          </div>
          <div class="map-cta">
            <p style="color:var(--color-gray-800); margin-bottom:1rem; line-height:1.6;">
              Not sure if we cover your area? Call or fill out our contact form.
            </p>
            <a href="/contact" class="btn-ghost">Contact Us →</a>
          </div>
        </div>

      </div>

      <!-- Services available in all areas -->
      <div style="margin-top:5rem;">
        <span class="eyebrow">All Services Available Across Our Coverage Area</span>
        <h2 style="margin-bottom:2rem;">Services We Provide</h2>
        <div class="service-area-links">
          {services.map(s => (
            <a href={`/services/${s.slug}`} class="service-area-link">
              <span style="color:var(--color-accent-500);">›</span>
              {s.title}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CtaBanner />

</BaseLayout>

<style>
.areas-layout {
  display: grid;
  grid-template-columns: 1fr 400px;
  gap: 4rem;
  align-items: start;
}
.areas-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}
.area-card {
  display: flex;
  gap: 1rem;
  padding: 1.25rem;
  background: var(--color-off-white);
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-gray-200);
}
.area-pin {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--color-accent-100);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-accent-700);
  flex-shrink: 0;
  margin-top: 2px;
}
.area-name { font-weight: 600; font-size: 1rem; margin-bottom: 0.25rem; }
.area-desc { font-size: 0.82rem; color: var(--color-gray-800); line-height: 1.5; margin-bottom: 0.25rem; }
.area-distance { font-size: 0.72rem; color: var(--color-gray-600); }
.areas-map-col { position: sticky; top: 100px; }
.map-embed {
  width: 100%;
  padding-bottom: 100%;
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  margin-bottom: 1.5rem;
}
.map-embed iframe { position: absolute; inset: 0; }
.service-area-links {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.5rem;
}
.service-area-link {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.875rem;
  color: var(--color-gray-800);
  padding: 0.5rem 0.75rem;
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-gray-200);
  transition: all var(--duration-fast);
}
.service-area-link:hover {
  background: var(--color-accent-100);
  border-color: var(--color-accent-300);
  color: var(--color-primary-700);
}
@media (max-width: 1023px) {
  .areas-layout { grid-template-columns: 1fr; }
  .areas-map-col { position: static; }
  .service-area-links { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 639px) {
  .areas-grid { grid-template-columns: 1fr; }
  .service-area-links { grid-template-columns: 1fr; }
}
</style>
