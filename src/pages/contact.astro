---
import { client } from '../../tina/__generated__/client';
import { prepareTinaData } from '../lib/tina-helper';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ui/ContactForm.astro';

const settingsResult = await client.queries.settings({ relativePath: 'main.md' });
const { tinaSetup } = prepareTinaData(settingsResult);
---

<BaseLayout
  title="Contact Us | [Company Name] — [City]"
  description="Contact [Company Name] for renovations, roofing & construction in [City]. Call [Phone], email us, or fill out our quick form. We respond within 1 business day."
  tinaSetup={tinaSetup}
>

  <!-- Hero -->
  <section
    style="background:linear-gradient(105deg,rgba(10,30,42,0.9) 0%,rgba(10,30,42,0.6) 100%),url('https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=1920&q=80') center/cover; padding-block:6rem 4rem;"
    aria-labelledby="contact-h1"
  >
    <div class="container" style="position:relative; z-index:1;">
      <span class="eyebrow">Get In Touch</span>
      <h1 id="contact-h1" style="color:white; max-width:560px; margin-bottom:1rem;">Let's Talk About Your Project</h1>
      <p style="color:rgba(255,255,255,0.8); max-width:480px; font-size:var(--text-lg);">
        We respond to every enquiry within 1 business day. Free estimates, no obligation.
      </p>
    </div>
  </section>

  <!-- Contact content -->
  <section class="section">
    <div class="container">
      <div class="contact-grid">

        <!-- Form -->
        <div>
          <h2 style="margin-bottom:0.5rem; font-size:var(--text-3xl);">Send Us a Message</h2>
          <p style="color:var(--color-gray-600); margin-bottom:2rem;">Fill out the form and we'll be in touch within 1 business day.</p>
          <ContactForm />
        </div>

        <!-- Contact info -->
        <div class="contact-info">
          <h2 style="margin-bottom:1.5rem; font-size:var(--text-3xl);">Contact Information</h2>

          <div class="contact-card">
            {[
              {
                icon: '<path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.12 1.18 2 2 0 012.11 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>',
                label: 'Phone',
                value: '[Phone]',
                href: 'tel:[Phone]',
              },
              {
                icon: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
                label: 'Email',
                value: 'info@[domain].ca',
                href: 'mailto:info@[domain].ca',
              },
              {
                icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>',
                label: 'Address',
                value: '[Address], [City], [Province] [Postal Code]',
                href: undefined,
              },
              {
                icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
                label: 'Hours',
                value: 'Monday – Friday: 8:00am – 5:00pm',
                href: undefined,
              },
            ].map(item => (
              <div class="contact-row">
                <div class="contact-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={item.icon} />
                </div>
                <div>
                  <p class="contact-row-label">{item.label}</p>
                  {item.href
                    ? <a href={item.href} class="contact-row-value contact-row-link">{item.value}</a>
                    : <p class="contact-row-value">{item.value}</p>
                  }
                </div>
              </div>
            ))}
          </div>

          <!-- Map placeholder -->
          <div class="map-wrap" aria-label="Map showing service area">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2800.0!2d-75.6972!3d45.4215!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDXCsDI1JzE3LjQiTiA3NcKwNDEnNTAuMCJX!5e0!3m2!1sen!2sca!4v1"
              width="100%"
              height="100%"
              style="border:0; border-radius:var(--radius-lg);"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="[Company Name] service area map"
            ></iframe>
          </div>

        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: start;
}
.contact-card {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  padding: 2rem;
  background: var(--color-off-white);
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-gray-200);
  margin-bottom: 2rem;
}
.contact-row {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}
.contact-icon {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--color-accent-100);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-accent-700);
  flex-shrink: 0;
}
.contact-row-label {
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-weight: 700;
  color: var(--color-gray-600);
  margin-bottom: 0.2rem;
}
.contact-row-value {
  font-weight: 500;
  color: var(--color-text);
  font-size: 0.95rem;
}
.contact-row-link { transition: color var(--duration-fast); }
.contact-row-link:hover { color: var(--color-primary-600); }
.map-wrap {
  width: 100%;
  padding-bottom: 56.25%;
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.map-wrap iframe {
  position: absolute;
  inset: 0;
}
@media (max-width: 1023px) {
  .contact-grid { grid-template-columns: 1fr; }
}
</style>
