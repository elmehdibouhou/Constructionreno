---
import { getCollection } from 'astro:content';
import { client } from '../../tina/__generated__/client';
import { prepareTinaData } from '../lib/tina-helper';
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';

const projectsResult = await client.queries.projectsConnection();
const { tinaSetup } = prepareTinaData(projectsResult);

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return 0;
});

const categories = ['All', ...new Set(projects.map(p => p.data.category))];
---

<BaseLayout
  title="Renovation Portfolio Ontario | Top Design Renovation"
  description="View completed renovation and roofing projects by Top Design Renovation in Ontario. Kitchen renovations, roof replacements, home additions & more."
  tinaSetup={tinaSetup}
>

  <!-- Hero -->
  <section
    style="background:linear-gradient(105deg,rgba(10,30,42,0.88) 0%,rgba(10,30,42,0.55) 100%),url('https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=1920&q=80') center/cover; padding-block:6rem 4rem;"
    aria-labelledby="work-h1"
  >
    <div class="container" style="position:relative; z-index:1;">
      <span class="eyebrow">Our Portfolio</span>
      <h1 id="work-h1" style="color:white; max-width:600px; margin-bottom:1rem;">Our Work</h1>
      <p style="color:rgba(255,255,255,0.8); max-width:500px; font-size:var(--text-lg);">
        Browse completed renovation and roofing projects across Ontario and the surrounding area.
      </p>
    </div>
  </section>

  <!-- Gallery with filter -->
  <section class="section">
    <div class="container">

      <!-- Filter bar -->
      <div class="gallery-filters" role="tablist" aria-label="Filter projects by category">
        {categories.map((cat, i) => (
          <button
            class:list={['filter-btn', { active: i === 0 }]}
            data-filter={cat === 'All' ? 'all' : cat}
            role="tab"
            aria-selected={i === 0}
            type="button"
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Project grid -->
      <div class="gallery-grid" id="gallery-grid">
        {projects.map((p, i) => (
          <div
            class:list={['gallery-project', { 'gallery-project--large': p.data.featured }]}
            data-category={p.data.category}
          >
            <a href={`/projects/${p.slug}`} class="gallery-project-inner img-overlay" aria-label={`View project: ${p.data.title}`}>
              <img
                src={p.data.img}
                alt={p.data.alt || p.data.title}
                width={p.data.featured ? 900 : 600}
                height={p.data.featured ? 600 : 400}
                loading={i < 4 ? 'eager' : 'lazy'}
                decoding="async"
                style="width:100%; height:100%; object-fit:cover;"
              />
              <div class="gallery-project-label">
                <p class="gallery-project-cat">{p.data.category}</p>
                <p class="gallery-project-title">{p.data.title}</p>
                <p class="gallery-project-city">{p.data.location}</p>
                <p class="gallery-project-cta">View Project →</p>
              </div>
            </a>
          </div>
        ))}
      </div>

    </div>
  </section>

  <CtaBanner
    heading="Inspired by What You See?"
    subtext="Every project starts with a free estimate. Tell us about your home and we'll make it happen."
  />

</BaseLayout>

<style>
.gallery-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 2.5rem;
}
.filter-btn {
  padding: 0.5rem 1.25rem;
  border-radius: var(--radius-full);
  border: 1.5px solid var(--color-gray-200);
  background: transparent;
  font-size: 0.82rem;
  font-weight: 500;
  color: var(--color-gray-800);
  cursor: pointer;
  transition: all var(--duration-fast);
  font-family: var(--font-body);
}
.filter-btn:hover { border-color: var(--color-primary-600); color: var(--color-primary-700); }
.filter-btn.active {
  background: var(--color-primary-700);
  border-color: var(--color-primary-700);
  color: white;
}
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  grid-auto-flow: dense;
}
.gallery-project { border-radius: var(--radius-md); overflow: hidden; }
.gallery-project--large { grid-column: span 2; }
.gallery-project-inner {
  display: block;
  position: relative;
  aspect-ratio: 4/3;
  border-radius: var(--radius-md);
  overflow: hidden;
  cursor: pointer;
  text-decoration: none;
}
.gallery-project--large .gallery-project-inner { aspect-ratio: 16/9; }
.gallery-project-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 1.25rem;
  z-index: 2;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity var(--duration-normal) var(--ease-out),
              transform var(--duration-normal) var(--ease-out);
}
.gallery-project:hover .gallery-project-label { opacity: 1; transform: translateY(0); }
.gallery-project-cat {
  font-size: 0.65rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-accent-300);
  font-weight: 600;
  margin-bottom: 0.2rem;
}
.gallery-project-title {
  font-weight: 600;
  color: white;
  font-size: 1rem;
  margin-bottom: 0.15rem;
}
.gallery-project-city {
  font-size: 0.78rem;
  color: rgba(255,255,255,0.65);
}
.gallery-project-cta {
  display: inline-block;
  margin-top: 0.5rem;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: var(--color-accent-300);
  text-transform: uppercase;
}
.gallery-project--hidden { display: none; }
@media (max-width: 1023px) {
  .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  .gallery-project--large { grid-column: span 2; }
}
@media (max-width: 639px) {
  .gallery-grid { grid-template-columns: 1fr; }
  .gallery-project--large { grid-column: span 1; }
}
</style>

<script>
  document.querySelectorAll('.filter-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');

      const filter = (btn as HTMLElement).dataset.filter ?? 'all';
      document.querySelectorAll('.gallery-project').forEach((project) => {
        const cat = (project as HTMLElement).dataset.category ?? '';
        const show = filter === 'all' || cat === filter;
        project.classList.toggle('gallery-project--hidden', !show);
      });
    });
  });
</script>
